<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root Menu -->
    <menuitem
        id="menu_transit_root"
        name="TransitOps"
        sequence="10"/>

    <!-- Dashboard -->
    <menuitem
        id="menu_transit_dashboard"
        name="Dashboard"
        parent="menu_transit_root"
        sequence="10"/>

    <!-- Vehicle -->
    <menuitem
        id="menu_transit_vehicle"
        name="Vehicle Management"
        parent="menu_transit_root"
        action="action_transit_vehicle"
        sequence="20"/>

    <!-- Driver -->
    <menuitem
        id="menu_transit_driver"
        name="Driver Management"
        parent="menu_transit_root"
        action="action_transit_driver"
        sequence="30"/>

    <!-- Trip -->
    <menuitem
        id="menu_transit_trip"
        name="Trip Management"
        parent="menu_transit_root"
        action="action_transit_trip"
        sequence="40"/>

</odoo>
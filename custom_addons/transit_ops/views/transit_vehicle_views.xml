<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List (Tree) View -->
    <record id="view_transit_vehicle_list" model="ir.ui.view">
        <field name="name">transit.vehicle.list</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="registration_number"/>
                <field name="vehicle_name"/>
                <field name="vehicle_type"/>
                <field name="max_load_capacity" sum="Total Capacity"/>
                <field name="odometer_reading"/>
                <field name="acquisition_cost" sum="Total Cost"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'available'" 
                       decoration-info="status == 'on_trip'" 
                       decoration-warning="status == 'in_shop'" 
                       decoration-danger="status == 'retired'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,in_shop,retired" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="vehicle_name" class="oe_edit_only"/>
                        <h1>
                            <field name="vehicle_name" placeholder="e.g. Delivery Truck #12"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="registration_number" placeholder="e.g. NY-1234-AB"/>
                            <field name="vehicle_type"/>
                        </group>
                        <group string="Specifications &amp; Costs">
                            <field name="max_load_capacity"/>
                            <field name="odometer_reading"/>
                            <field name="acquisition_cost"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_transit_vehicle_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="vehicle_name" string="Vehicle" filter_domain="['|', ('vehicle_name', 'ilike', self), ('registration_number', 'ilike', self)]"/>
                <field name="registration_number"/>
                <field name="vehicle_type"/>
                <separator/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                <filter string="In Shop" name="in_shop" domain="[('status', '=', 'in_shop')]"/>
                <filter string="Retired" name="retired" domain="[('status', '=', 'retired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vehicle Type" name="group_by_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new vehicle to your fleet
            </p>
            <p>
                Manage your fleet vehicle details, track load capacity, odometer readings, and operational status.
            </p>
        </field>
    </record>
</odoo>

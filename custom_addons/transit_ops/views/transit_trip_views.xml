<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_transit_trip_tree" model="ir.ui.view">
        <field name="name">transit.trip.tree</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <tree string="Trips">
                <field name="trip_reference"/>
                <field name="source_location"/>
                <field name="destination_location"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="planned_distance"/>
                <field name="trip_status"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_transit_trip_form" model="ir.ui.view">
        <field name="name">transit.trip.form</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>

                    <button name="action_dispatch"
                            type="object"
                            string="Dispatch"
                            class="btn-primary"
                            invisible="trip_status != 'draft'"/>

                    <button name="action_complete"
                            type="object"
                            string="Complete"
                            class="btn-success"
                            invisible="trip_status != 'dispatched'"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="trip_status in ('completed','cancelled')"/>

                    <field name="trip_status" widget="statusbar"/>

                </header>

                <sheet>

                    <group>
                        <group>
                            <field name="trip_reference" readonly="1"/>
                            <field name="source_location"/>
                            <field name="destination_location"/>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                        </group>

                        <group>
                            <field name="cargo_weight"/>
                            <field name="planned_distance"/>
                            <field name="dispatch_date" readonly="1"/>
                            <field name="completion_date" readonly="1"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_transit_trip_search" model="ir.ui.view">
        <field name="name">transit.trip.search</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <search>
                <field name="trip_reference"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>

                <filter string="Draft"
                        name="draft"
                        domain="[('trip_status','=','draft')]"/>

                <filter string="Dispatched"
                        name="dispatched"
                        domain="[('trip_status','=','dispatched')]"/>

                <filter string="Completed"
                        name="completed"
                        domain="[('trip_status','=','completed')]"/>

                <filter string="Cancelled"
                        name="cancelled"
                        domain="[('trip_status','=','cancelled')]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transit_trip" model="ir.actions.act_window">
        <field name="name">Trip Management</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category for TransitOps -->
        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Access rights and roles classification for TransitOps system.</field>
            <field name="sequence">20</field>
        </record>

        <!-- TransitOps Groups -->

        <!-- Fleet Manager Group -->
        <record id="group_transit_fleet_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Users with management access to vehicles, drivers, and operational logs.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Driver Group -->
        <record id="group_transit_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Transit drivers who can access their assigned vehicles and update trip logs.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Safety Officer Group -->
        <record id="group_transit_safety_officer" model="res.groups">
            <field name="name">Safety Officer</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Users responsible for safety audits, compliance reports, and incident management.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Financial Analyst Group -->
        <record id="group_transit_financial_analyst" model="res.groups">
            <field name="name">Financial Analyst</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="comment">Users who can access fuel logs, maintenance costs, and financial analytics.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>

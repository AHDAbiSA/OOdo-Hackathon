<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_maintenance_list" model="ir.ui.view">
        <field name="name">transitops.maintenance.list</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehicle_id"/>
                <field name="description"/>
                <field name="cost"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_maintenance_form" model="ir.ui.view">
        <field name="name">transitops.maintenance.form</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="description"/>
                        <field name="cost"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transitops.maintenance</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="transitops_maintenance_menu"
              name="Maintenance"
              parent="transitops_expenses.transitops_root_menu"
              action="action_transitops_maintenance"
              sequence="20"/>

</odoo>

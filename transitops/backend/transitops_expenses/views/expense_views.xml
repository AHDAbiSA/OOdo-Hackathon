<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_expense_list" model="ir.ui.view">
        <field name="name">transitops.expense.list</field>
        <field name="model">transitops.expense</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehicle_id"/>
                <field name="expense_type"/>
                <field name="amount"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_expense_form" model="ir.ui.view">
        <field name="name">transitops.expense.form</field>
        <field name="model">transitops.expense</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="expense_type"/>
                        <field name="amount"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>